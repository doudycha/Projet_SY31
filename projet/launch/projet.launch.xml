<launch>
  <!-- Nœud de détection de formes colorées (rouge + bleu) par caméra -->
  <node pkg="projet" exec="detector_node" name="detector" output="screen"/>

  <!-- Nœud de conversion LiDAR : LaserScan → PointCloud2 cartésien + trilatération robot_position -->
  <node pkg="projet" exec="transformer_node" name="transformer" output="screen"/>

  <!-- Nœud de filtrage par intensité LiDAR -->
  <node pkg="projet" exec="intensity_filter_node" name="intensity_filter" output="screen">
    <param name="intensity_threshold" value="10000.0"/>
  </node>

  <!-- Nœud d'odométrie : encodeurs + gyroscope + magnétomètre → pose_enco / pose_gyro / pose_magn -->
  <!-- Nécessite turtlebot3_msgs pour le callback encodeur (/sensor_state) -->
  <!-- Le callback gyroscope (/imu) et magnétomètre (/magnetic_field) fonctionnent sans -->
  <node pkg="projet" exec="odompose_node" name="odom_to_pose" output="screen"/>

  <!-- Nœud de fusion : combine LiDAR + odométrie + caméra → carte globale /map_points -->
  <node pkg="projet" exec="pipeline_node" name="pipeline" output="screen">
    <param name="position_threshold" value="0.5"/>
  </node>
</launch>
